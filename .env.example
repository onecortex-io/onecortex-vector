# ── Database ──────────────────────────────────────────────────────────────────
# Required. Connection string for the PostgreSQL database.
ONECORTEX_VECTOR_DATABASE_URL=postgres://onecortex_vector:onecortex_vector@localhost:5432/onecortex_vector
# Optional. Direct connection URL for migrations, bypasses PgBouncer (Phase 8+).
# ONECORTEX_VECTOR_DATABASE_URL_DIRECT=postgres://onecortex_vector:onecortex_vector@localhost:5432/onecortex_vector

# ── Server ────────────────────────────────────────────────────────────────────
# Public API port. Default: 8080
ONECORTEX_VECTOR_API_PORT=8080
# Admin/metrics port. Default: 9090
ONECORTEX_VECTOR_ADMIN_PORT=9090
# Hostname returned in index descriptors. Default: localhost
ONECORTEX_VECTOR_API_HOST=localhost
# Log level: trace | debug | info | warn | error. Default: info
ONECORTEX_VECTOR_LOG_LEVEL=info

# ── Connection pool ───────────────────────────────────────────────────────────
# Max PostgreSQL connections in the pool. Default: 50
ONECORTEX_VECTOR_MAX_CONNS=50

# ── DiskANN index defaults ────────────────────────────────────────────────────
# Number of neighbors for DiskANN graph construction. Default: 50
ONECORTEX_VECTOR_DEFAULT_DISKANN_NEIGHBORS=50
# Search list size for DiskANN queries. Default: 100
ONECORTEX_VECTOR_DEFAULT_DISKANN_SEARCH_LIST=100

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
# Enable PostgreSQL Row-Level Security for namespace isolation. Default: false
ONECORTEX_VECTOR_ENABLE_RLS=false

# ── Reranking ─────────────────────────────────────────────────────────────────
# Reranking backend. Values: none | cohere | voyage | jina | pinecone | cross-encoder
# Default: none (reranking disabled)
ONECORTEX_VECTOR_RERANK_BACKEND=none
# Timeout in seconds for reranker HTTP calls. Default: 30
ONECORTEX_VECTOR_RERANK_HTTP_TIMEOUT_SECS=30
# Max retry attempts on 429 rate-limit responses (cloud backends only). Default: 3
ONECORTEX_VECTOR_RERANK_MAX_RETRIES=3

# Cohere — required when RERANK_BACKEND=cohere
# ONECORTEX_VECTOR_RERANK_COHERE_API_KEY=your-cohere-api-key
# Model options: rerank-v3.5 (default), rerank-v4.0-pro, rerank-english-v3.0
ONECORTEX_VECTOR_RERANK_COHERE_MODEL=rerank-v3.5

# Voyage AI — required when RERANK_BACKEND=voyage
# ONECORTEX_VECTOR_RERANK_VOYAGE_API_KEY=your-voyage-api-key
# Model options: rerank-2.5 (default), rerank-2.5-lite, rerank-2, rerank-lite-1
ONECORTEX_VECTOR_RERANK_VOYAGE_MODEL=rerank-2.5

# Jina AI — required when RERANK_BACKEND=jina
# ONECORTEX_VECTOR_RERANK_JINA_API_KEY=your-jina-api-key
# Model options: jina-reranker-v2-base-multilingual (default), jina-reranker-v1-base-en
ONECORTEX_VECTOR_RERANK_JINA_MODEL=jina-reranker-v2-base-multilingual

# Pinecone Inference — required when RERANK_BACKEND=pinecone
# ONECORTEX_VECTOR_RERANK_PINECONE_API_KEY=your-pinecone-api-key
# Model options: pinecone-rerank-v0 (default), bge-reranker-v2-m3, cohere-rerank-3.5
ONECORTEX_VECTOR_RERANK_PINECONE_MODEL=pinecone-rerank-v0

# Self-hosted cross-encoder via TEI — required when RERANK_BACKEND=cross-encoder
# ONECORTEX_VECTOR_RERANK_CROSS_ENCODER_URL=http://cross-encoder:8080
